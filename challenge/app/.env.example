# ─────────────────────────────────────────────
# GitHub OAuth App credentials
# Register at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ─────────────────────────────────────────────
# Target repository for student Pull Requests
# Format: owner/repo  (the upstream instructor-owned repo)
# ─────────────────────────────────────────────
TARGET_REPO=your-org/machine-learning-lab-2026

# ─────────────────────────────────────────────
# Submission deadline (ISO 8601, UTC)
# Students cannot submit after this timestamp.
# Example: 2026-04-01T23:59:59Z
# ─────────────────────────────────────────────
DEADLINE=2026-04-01T23:59:59Z

# ─────────────────────────────────────────────
# Instructor dashboard password
# Protects the /instructor route in the app.
# ─────────────────────────────────────────────
INSTRUCTOR_PASSWORD=change_me_before_distribution

# ─────────────────────────────────────────────
# Session secret key (generate a random string)
# Used to sign server-side sessions.
# ─────────────────────────────────────────────
SESSION_SECRET=replace_with_a_long_random_string

# ─────────────────────────────────────────────
# Personal Access Token for the instructor
# Used to read PR branches and download model.pkl files for scoring.
# Needs: repo (read) scope on the TARGET_REPO.
# Create at: https://github.com/settings/tokens
# ─────────────────────────────────────────────
GITHUB_INSTRUCTOR_TOKEN=ghp_your_instructor_token_here

# ─────────────────────────────────────────────
# Frontend origin (used for CORS + OAuth redirects)
# Default: http://localhost:3000   (leave unchanged for Docker Compose)
# ─────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
